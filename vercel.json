{
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/org-os run build",
  "outputDirectory": "artifacts/org-os/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "github": {
    "silent": true
  }
}
